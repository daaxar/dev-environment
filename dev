#!/bin/bash

# Script para gestionar el contenedor de desarrollo aislado

export DEV_CONTAINER_NAME="dev-isolated-$(basename $PWD)"
COMPOSE_PROJECT="dev-$(basename $PWD)"
DC="docker compose -f /home/daaxar/dev/daaxar/envDev/docker-compose.yml -p $COMPOSE_PROJECT"

case "$1" in
    start)
        echo "🚀 Iniciando contenedor de desarrollo aislado..."
        $DC up -d && \
        echo "✅ Contenedor iniciado" && \
        echo "📝 Usa './dev shell' para acceder"
        ;;
    
    stop)
        echo "🛑 Deteniendo contenedor..."
        $DC down && \
        echo "✅ Contenedor detenido"
        ;;
    
    shell|bash)
        echo "🔧 Accediendo al contenedor..."
        $DC exec dev-container bash
        ;;
    
    restart)
        echo "🔄 Reiniciando contenedor..."
        $DC restart && \
        echo "✅ Contenedor reiniciado"
        ;;
    
    rebuild)
        echo "🔨 Reconstruyendo contenedor..."
        $DC down && \
        $DC build --no-cache && \
        $DC up -d && \
        echo "✅ Contenedor reconstruido"
        ;;
    
    build)
        echo "🔨 Reconstruyendo contenedor..."
        $DC down && \
        $DC build && \
        $DC up -d && \
        echo "✅ Contenedor reconstruido"
        ;;
    
    update)
        echo "🔨 Reconstruyendo contenedor..."
        $DC build && \
        echo "✅ Contenedor reconstruido"
        ;;
    
    logs)
        $DC logs -f dev-container
        ;;
    
    clean)
        echo "🧹 Limpiando contenedor y volúmenes..."
        $DC down -v && \
        echo "✅ Limpieza completada"
        ;;
    
    status)
        echo "📊 Estado del contenedor:"
        $DC ps
        ;;
    
    *)
        echo "🤖 Contenedor de Desarrollo Aislado"
        echo ""
        echo "Uso: ./dev.sh [comando]"
        echo ""
        echo "Comandos disponibles:"
        echo "  start     - Iniciar el contenedor"
        echo "  stop      - Detener el contenedor"
        echo "  shell     - Abrir shell en el contenedor"
        echo "  restart   - Reiniciar el contenedor"
        echo "  rebuild   - Reconstruir el contenedor desde cero"
        echo "  update    - Reconstruir el contenedor desde cache"
        echo "  build     - Reconstruir el contenedor"
        echo "  logs      - Ver logs del contenedor"
        echo "  clean     - Eliminar contenedor y volúmenes"
        echo "  status    - Ver estado del contenedor"
        echo ""
        echo "Ejemplo: ./dev.sh start"
        ;;
esac
